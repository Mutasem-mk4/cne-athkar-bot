# ضع هنا التوكن من BotFather
BOT_TOKEN=your_bot_token_here

# ضع هنا ID قروب واحد
GROUP_CHAT_ID=your_group_chat_id_here

# أو ضع أكثر من قروب مفصولين بفواصل
# GROUP_CHAT_IDS=-1001234567890,-1009876543210

# التوقيت المحلي (Asia/Amman للأردن، Asia/Riyadh للسعودية)
TIMEZONE=Asia/Amman

# رابط قاعدة البيانات
MONGODB_URI=mongodb+srv://...

# مفتاح سري لحماية نقاط Cron (اختياري لكن مُنصح به)
CRON_SECRET=your_secret_key_here

# معرف المسؤول (للأوامر الإدارية)
ADMIN_ID=your_admin_telegram_id_here
